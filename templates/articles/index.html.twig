{% extends 'base.html.twig' %}
{% block title %}Liste des Articles{% endblock %}

{% block body %}
<h2>Liste des Articles</h2>
<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th><th>Nom</th><th>Prix (DT)</th><th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for article in articles %}
        <tr>
            <td>{{ article.id }}</td>
            <td>{{ article.nom }}</td>
            <td>{{ article.prix }}</td>
            <td>
                <a href="{{ path('article_show', {id: article.id}) }}" class="btn btn-info btn-sm">Voir</a>
                <a href="{{ path('article_edit', {id: article.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                <a href="{{ path('article_delete', {id: article.id}) }}"
                   class="btn btn-danger btn-sm"
                   onclick="return confirm('Supprimer cet article ?')">Supprimer</a>
            </td>
        </tr>
    {% else %}
        <tr><td colspan="4" class="text-center">Aucun article trouvé.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
